{
  "manifest_version": 3,
  "name": "Glance New Tab by sameerasw.com",
  "short_name": "Glance",
  "version": "2.0",
  "description": "Replaces the new tab page with a grid of bookmarks from a chosen folder. Customizable layout and style.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "bookmarks",
    "storage",
    "topSites",
    "contextMenus",
    "favicon",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://www.bing.com/",
    "https://sameerasw.com/",
    "https://images.unsplash.com/"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "options_page": "options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
